---
import TiktokShell from "../../components/TiktokShell.astro";
import { getTikTokConfig } from "../../lib/tiktok/config.js";
import { getConnectionByTargetAccount } from "../../lib/tiktok/store.js";
import { getReadyTikTokTaskByTargetAccount } from "../../lib/tiktok/tasks.js";
import { getTikTokBannerState } from "../../lib/tiktok/view-state.js";

export const prerender = false;

const config = getTikTokConfig(import.meta.env);
const connection = config.nocodbConfigured
  ? await getConnectionByTargetAccount(config, config.targetAccount)
  : null;
const task = config.nocodbConfigured
  ? await getReadyTikTokTaskByTargetAccount(config, config.targetAccount)
  : null;
const callbackStatus = Astro.url.searchParams.get("callback");
const callbackMessage = Astro.url.searchParams.get("message");
const taskUpdateStatus = Astro.url.searchParams.get("task_update");
const taskUpdateMessage = Astro.url.searchParams.get("message");
const publishStatus = Astro.url.searchParams.get("publish");
const publishMessage = Astro.url.searchParams.get("message");
const tikTokPrivacyOptions = [
  "PUBLIC_TO_EVERYONE",
  "MUTUAL_FOLLOW_FRIENDS",
  "FOLLOWER_OF_CREATOR",
  "SELF_ONLY",
];
const banner = getTikTokBannerState({
  callbackStatus,
  callbackMessage,
  connection,
});
---

<TiktokShell
  title="Publicar en TikTok | Espacio Sutil"
  description="Miniapp inicial para conectar una cuenta TikTok y revisar la publicación asistida de shorts."
>
  <section class="grid w-full gap-8 lg:grid-cols-[1.15fr_0.85fr]">
    <article class="rounded border border-white/10 bg-slate-900/80 p-8 shadow-2xl shadow-cyan-950/30 backdrop-blur">
      <p class="mb-4 inline-flex rounded-full border border-cyan-400/30 bg-cyan-400/10 px-3 py-1 text-sm uppercase tracking-[0.2em] text-cyan-200">
        Sandbox TikTok
      </p>
      <h1 class="max-w-3xl text-4xl font-semibold leading-tight text-white sm:text-5xl">
        Publicar en TikTok con revisión previa y autorización explícita.
      </h1>
      <p class="mt-5 max-w-2xl text-lg leading-8 text-slate-300">
        Esta miniapp ya puede iniciar la autorización de <strong class="text-white">TikTok Login Kit</strong>,
        recibir el callback del lado servidor, guardar la sesión conectada en <strong class="text-white">NocoDB</strong>
        y cargar una tarea editorial real de <strong class="text-white">distribution_tasks</strong>.
      </p>

      <div class:list={["mt-8 rounded border px-5 py-4 text-sm leading-7", banner.tone]}>
        <p class="font-semibold">{banner.title}</p>
        <p class="mt-1">{banner.message}</p>
      </div>

      <div class="mt-8 grid gap-4 sm:grid-cols-3">
        <div class="rounded border border-white/8 bg-white/5 p-5">
          <p class="text-sm uppercase tracking-[0.18em] text-slate-400">Paso 1</p>
          <h2 class="mt-2 text-xl font-semibold text-white">Conectar TikTok</h2>
          <p class="mt-3 text-sm leading-6 text-slate-300">
            La miniapp abre Login Kit y valida el callback de forma segura en servidor.
          </p>
        </div>
        <div class="rounded border border-white/8 bg-white/5 p-5">
          <p class="text-sm uppercase tracking-[0.18em] text-slate-400">Paso 2</p>
          <h2 class="mt-2 text-xl font-semibold text-white">Guardar tokens</h2>
          <p class="mt-3 text-sm leading-6 text-slate-300">
            La autorización se persiste en la tabla `tiktok_connections` asociada al destino editorial.
          </p>
        </div>
        <div class="rounded border border-white/8 bg-white/5 p-5">
          <p class="text-sm uppercase tracking-[0.18em] text-slate-400">Paso 3</p>
          <h2 class="mt-2 text-xl font-semibold text-white">Revisar la tarea</h2>
          <p class="mt-3 text-sm leading-6 text-slate-300">
            La pantalla carga la tarea lista para TikTok y deja preparado el siguiente paso de publicación asistida.
          </p>
        </div>
      </div>
    </article>

    <aside class="space-y-6">
      <div class="rounded border border-cyan-400/20 bg-slate-900/80 p-7 shadow-xl shadow-cyan-950/25 backdrop-blur">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="text-sm uppercase tracking-[0.18em] text-cyan-200">Estado actual</p>
            <h2 class="mt-2 text-2xl font-semibold text-white">
              {connection ? "Cuenta conectada" : "Conexión pendiente"}
            </h2>
          </div>
          <span class="rounded-full border border-amber-400/30 bg-amber-400/10 px-3 py-1 text-xs font-medium uppercase tracking-[0.18em] text-amber-200">
            {config.configured && config.nocodbConfigured
              ? "OAuth listo"
              : config.configured
                ? "Falta NocoDB"
                : "Faltan secretos"}
          </span>
        </div>

        {
          connection ? (
            <div class="mt-5 flex items-center gap-4 rounded border border-white/10 bg-black/15 p-4">
              {connection.avatarUrl ? (
                <img
                  src={connection.avatarUrl}
                  alt={`Avatar de ${connection.displayName}`}
                  class="h-14 w-14 rounded object-cover"
                />
              ) : (
                <div class="flex h-14 w-14 items-center justify-center rounded bg-white/10 text-lg font-semibold text-cyan-100">
                  {connection.displayName?.slice(0, 1) ?? "T"}
                </div>
              )}
              <div>
                <p class="font-semibold text-white">{connection.displayName}</p>
                <p class="text-sm text-slate-300">Destino editorial: {connection.targetAccount}</p>
                <p class="text-xs text-slate-400">
                  {connection.expiresAt
                    ? `Expira: ${new Date(connection.expiresAt).toLocaleString("es-ES")}`
                    : "Sin fecha de expiración registrada"}
                </p>
              </div>
            </div>
          ) : (
            <p class="mt-4 text-sm leading-7 text-slate-300">
              {
                config.nocodbConfigured
                  ? (
                    <>
                      Todavía no hay una cuenta TikTok guardada para <strong class="text-white">{config.targetAccount}</strong>.
                    </>
                  )
                  : (
                    <>
                      Falta la configuración de <strong class="text-white">NocoDB</strong> para poder guardar la conexión de <strong class="text-white">{config.targetAccount}</strong>.
                    </>
                  )
              }
            </p>
          )
        }

        <div class="mt-6 space-y-3">
          <a
            href={`/api/tiktok/login?target_account=${encodeURIComponent(config.targetAccount)}`}
            class="flex items-center justify-center rounded bg-cyan-400 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-300"
          >
            Conectar TikTok
          </a>
          <a
            href="/"
            class="flex items-center justify-center rounded border border-white/10 px-5 py-3 text-sm font-medium text-slate-200 transition hover:border-white/20 hover:bg-white/5"
          >
            Volver al sitio principal
          </a>
        </div>
      </div>

      <div class="rounded border border-white/10 bg-slate-900/70 p-7">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="text-sm uppercase tracking-[0.18em] text-slate-400">Tarea editorial</p>
            <h2 class="mt-2 text-2xl font-semibold text-white">
              {task ? `Lista para revisar (#${task.id})` : "Sin tarea TikTok lista"}
            </h2>
          </div>
          {
            task ? (
              <span class="rounded-full border border-emerald-400/30 bg-emerald-400/10 px-3 py-1 text-xs font-medium uppercase tracking-[0.18em] text-emerald-200">
                {task.state}
              </span>
            ) : null
          }
        </div>

        {
          task ? (
            <div class="mt-6 space-y-5">
              <div class="overflow-hidden rounded border border-white/10 bg-black/20">
                <video
                  class="aspect-[9/16] w-full bg-black object-contain"
                  src={task.resolvedPreviewAssetUrl ?? undefined}
                  poster={task.resolvedCoverUrl ?? undefined}
                  controls
                  preload="metadata"
                />
              </div>

              <div class="space-y-4 text-sm leading-7 text-slate-300">
                <div>
                  <p class="text-slate-500">Título</p>
                  <p class="mt-1 text-base font-semibold text-white">{task.title || "Sin título"}</p>
                </div>
                <div>
                  <p class="text-slate-500">Texto de publicación</p>
                  <p class="mt-1 whitespace-pre-line">{task.captionText || "Sin caption_text"}</p>
                </div>
                <div>
                  <p class="text-slate-500">Hashtags</p>
                  <p class="mt-1 break-words">{task.hashtags || "Sin hashtags"}</p>
                </div>
                <div class="grid gap-4 sm:grid-cols-2">
                  <div>
                    <p class="text-slate-500">Destino editorial</p>
                    <p class="mt-1">{task.targetAccount}</p>
                  </div>
                  <div>
                    <p class="text-slate-500">Pieza</p>
                    <p class="mt-1">{task.pieceDir || "Sin piece_dir"}</p>
                  </div>
                </div>
                <div>
                  <p class="text-slate-500">Asset resuelto para previsualización</p>
                  <p class="mt-1 break-all text-cyan-100">{task.resolvedPreviewAssetUrl || "Sin vídeo resuelto"}</p>
                </div>
                {
                  task.resolvedAssetFallbackUrl ? (
                    <div>
                      <p class="text-slate-500">Asset TikTok previsto</p>
                      <p class="mt-1 break-all text-slate-300">{task.resolvedAssetUrl}</p>
                      <p class="mt-1 text-xs text-slate-500">
                        La previsualización usa el fallback `master/video.mp4` mientras no exista una variante `tiktok/video.mp4`.
                      </p>
                    </div>
                  ) : null
                }
              </div>

              <form method="POST" action="/api/tiktok/task-settings" class="space-y-5 rounded border border-white/10 bg-black/10 p-5">
                <input type="hidden" name="task_id" value={task.id} />
                <div>
                  <p class="text-sm uppercase tracking-[0.16em] text-slate-400">Configuración TikTok</p>
                  <p class="mt-2 text-sm leading-6 text-slate-300">
                    Guarda aquí la privacidad y las interacciones que consumirá la publicación directa desde esta miniapp.
                  </p>
                </div>

                {
                  taskUpdateStatus ? (
                    <div
                      class:list={[
                        "rounded border px-4 py-3 text-sm leading-6",
                        taskUpdateStatus === "success"
                          ? "border-emerald-400/25 bg-emerald-400/10 text-emerald-100"
                          : "border-rose-400/25 bg-rose-400/10 text-rose-100",
                      ]}
                    >
                      {taskUpdateMessage}
                    </div>
                  ) : null
                }

                <label class="block">
                  <span class="text-sm text-slate-400">Privacidad TikTok</span>
                  <select
                    name="tiktok_privacy_level"
                    class="mt-2 w-full rounded border border-white/10 bg-slate-950 px-4 py-3 text-sm text-white"
                  >
                    {
                      tikTokPrivacyOptions.map((option) => (
                        <option
                          value={option}
                          selected={(task.tiktokPrivacyLevel ?? "SELF_ONLY") === option}
                        >
                          {option}
                        </option>
                      ))
                    }
                  </select>
                </label>

                <div class="grid gap-3 sm:grid-cols-3">
                  <label class="flex items-start gap-3 rounded border border-white/10 bg-slate-950/60 p-4 text-sm text-slate-200">
                    <input
                      type="checkbox"
                      name="tiktok_disable_comment"
                      class="mt-1"
                      checked={task.tiktokDisableComment}
                    />
                    <span>
                      <strong class="block text-white">Comentarios</strong>
                      Desactiva comentarios al publicar.
                    </span>
                  </label>

                  <label class="flex items-start gap-3 rounded border border-white/10 bg-slate-950/60 p-4 text-sm text-slate-200">
                    <input
                      type="checkbox"
                      name="tiktok_disable_duet"
                      class="mt-1"
                      checked={task.tiktokDisableDuet}
                    />
                    <span>
                      <strong class="block text-white">Duet</strong>
                      Desactiva la opción `Duet`.
                    </span>
                  </label>

                  <label class="flex items-start gap-3 rounded border border-white/10 bg-slate-950/60 p-4 text-sm text-slate-200">
                    <input
                      type="checkbox"
                      name="tiktok_disable_stitch"
                      class="mt-1"
                      checked={task.tiktokDisableStitch}
                    />
                    <span>
                      <strong class="block text-white">Stitch</strong>
                      Desactiva la opción `Stitch`.
                    </span>
                  </label>
                </div>

                <div class="flex flex-wrap gap-3">
                  <button
                    type="submit"
                    class="rounded bg-cyan-400 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-300"
                  >
                    Guardar ajustes TikTok
                  </button>
                </div>
              </form>

              <form method="POST" action="/api/tiktok/publish" class="space-y-4 rounded border border-cyan-400/20 bg-cyan-400/5 p-5">
                <input type="hidden" name="task_id" value={task.id} />
                <div>
                  <p class="text-sm uppercase tracking-[0.16em] text-cyan-200">Publicación TikTok</p>
                  <p class="mt-2 text-sm leading-6 text-slate-300">
                    La miniapp ejecuta el `FILE_UPLOAD` directamente contra TikTok con esta tarea exacta y actualiza `distribution_tasks` con el estado final.
                  </p>
                </div>

                {
                  publishStatus ? (
                    <div
                      class:list={[
                        "rounded border px-4 py-3 text-sm leading-6",
                        publishStatus === "success"
                          ? "border-emerald-400/25 bg-emerald-400/10 text-emerald-100"
                          : "border-rose-400/25 bg-rose-400/10 text-rose-100",
                      ]}
                    >
                      {publishMessage}
                    </div>
                  ) : null
                }

                <button
                  type="submit"
                  class="rounded border border-cyan-300/40 bg-cyan-300/90 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-200"
                >
                  Publicar en TikTok
                </button>
              </form>
            </div>
          ) : (
            <p class="mt-4 text-sm leading-7 text-slate-300">
              No hay ninguna tarea `ready` para <strong class="text-white">{config.targetAccount}</strong> en
              <strong class="text-white"> distribution_tasks</strong>.
            </p>
          )
        }
      </div>

      <div class="rounded border border-white/10 bg-slate-900/70 p-7">
        <p class="text-sm uppercase tracking-[0.18em] text-slate-400">Configuración actual</p>
        <dl class="mt-4 space-y-4 text-sm leading-7 text-slate-300">
          <div>
            <dt class="text-slate-500">Redirect URI</dt>
            <dd class="mt-1 rounded border border-white/8 bg-black/20 px-4 py-3 text-cyan-100">
              {config.redirectUri}
            </dd>
          </div>
          <div>
            <dt class="text-slate-500">Cuenta objetivo</dt>
            <dd class="mt-1">{config.targetAccount}</dd>
          </div>
          <div>
            <dt class="text-slate-500">Scopes solicitados</dt>
            <dd class="mt-1">{config.scope}</dd>
          </div>
          <div>
            <dt class="text-slate-500">Tabla de conexiones</dt>
            <dd class="mt-1">{config.nocodbTikTokConnectionsTableId}</dd>
          </div>
          <div>
            <dt class="text-slate-500">Tabla de tareas</dt>
            <dd class="mt-1">{config.nocodbDistributionTasksTableId}</dd>
          </div>
        </dl>
      </div>
    </aside>
  </section>
</TiktokShell>
